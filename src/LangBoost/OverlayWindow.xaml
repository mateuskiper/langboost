<Window x:Class="LangBoost.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LangBoost"
        Width="900"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Botões de ícone (engrenagem/fechar), quadrados. -->
        <Style x:Key="OverlayIconButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <!-- Alça arrastável do recorte. -->
        <Style x:Key="TrimThumb" TargetType="Thumb">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" Background="#FF4C8BF5" BorderBrush="White" BorderThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" Padding="18,14" Background="#E61B1B1F" MouseLeftButtonDown="OnDragBar">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                <TextBlock x:Name="StatusText"
                           Foreground="#FF9AA0A6" FontSize="13" FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           Text="Pressione Ctrl+Shift+Space para transcrever os últimos 5s"/>

                <TextBlock x:Name="OriginalText"
                           Foreground="White" FontSize="22" FontFamily="Segoe UI" FontWeight="SemiBold"
                           TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>

                <TextBlock x:Name="TranslationText"
                           Foreground="#FFB7E1FF" FontSize="17" FontFamily="Segoe UI" FontStyle="Italic"
                           TextWrapping="Wrap" Margin="0,4,0,0" Visibility="Collapsed"/>

                <!-- Player do resultado: só tocar/parar o trecho enviado. -->
                <Button x:Name="ResultPlayButton" Style="{StaticResource FlatButton}"
                        Content="&#x25B6; Ouvir áudio" Padding="12,6" FontSize="13"
                        HorizontalAlignment="Left" Margin="0,10,0,0"
                        Visibility="Collapsed" Click="OnResultPlayClick"/>

                <!-- Player de recorte: ouvir e selecionar o trecho a transcrever. -->
                <StackPanel x:Name="ReviewPanel" Visibility="Collapsed" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ReviewPlayButton" Style="{StaticResource FlatButton}"
                                Content="&#x25B6; Tocar" Padding="12,6" FontSize="13"
                                Click="OnReviewPlayClick"/>
                        <TextBlock x:Name="TimeLabel" Foreground="#FF9AA0A6"
                                   FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center"
                                   Margin="12,0,0,0" Text="00:00.0 / 00:00.0"/>
                    </StackPanel>

                    <Canvas Width="560" Height="44" Margin="0,12,0,0"
                            HorizontalAlignment="Left" Background="Transparent">
                        <Border Width="560" Height="20" Canvas.Top="12"
                                CornerRadius="4" Background="#FF2A2A30"/>
                        <Border x:Name="SelectionBar" Height="20" Canvas.Top="12"
                                Background="#664C8BF5"/>
                        <Rectangle x:Name="Playhead" Width="2" Height="44" Fill="White" Visibility="Collapsed"/>
                        <Thumb x:Name="StartThumb" Style="{StaticResource TrimThumb}"
                               DragDelta="OnStartThumbDrag"/>
                        <Thumb x:Name="EndThumb" Style="{StaticResource TrimThumb}"
                               DragDelta="OnEndThumbDrag"/>
                    </Canvas>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Style="{StaticResource FlatButton}"
                                Content="Cancelar" Padding="14,7" FontSize="14"
                                Margin="0,0,10,0" Click="OnReviewCancelClick"/>
                        <Button Style="{StaticResource FlatButton}"
                                Content="Enviar" Padding="14,7" FontSize="14" Click="OnReviewSendClick"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Style="{StaticResource OverlayIconButton}"
                        Content="&#x2699;" ToolTip="Configurações" Click="OnSettingsClick"/>
                <Button Style="{StaticResource OverlayIconButton}"
                        Content="&#x2715;" ToolTip="Encerrar" Click="OnCloseClick"/>
                <Button x:Name="DoneButton" Style="{StaticResource FlatButton}"
                        Content="Concluir" Padding="14,7" FontSize="14"
                        Visibility="Collapsed" Click="OnDoneClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
