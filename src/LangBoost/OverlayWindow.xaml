<Window x:Class="LangBoost.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LangBoost"
        Width="900"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Draggable trim handle: rounded bar with a centre grip + hover. -->
        <Style x:Key="TrimThumb" TargetType="Thumb">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" CornerRadius="5" Background="{StaticResource AccentBrush}"
                                BorderBrush="White" BorderThickness="1.5">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Rectangle Width="2" Height="14" Fill="#CCFFFFFF" RadiusX="1" RadiusY="1" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Selection region: drag to shift the whole [start,end] window. -->
        <Style x:Key="SelectionThumb" TargetType="Thumb">
            <Setter Property="Cursor" Value="ScrollAll"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" Background="#804C8BF5"
                                BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,2,0,2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#994C8BF5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Margin gives the drop shadow room to render as a soft rounded glow instead of
         being clipped by the window bounds into a rectangular halo.
         The shadow lives on a dedicated background layer with no children: applying an
         Effect rasterises the whole subtree (and drops ClearType), so the text must NOT
         sit under the effect — it goes in a separate, effect-free content layer on top. -->
    <Grid Margin="22">
        <Border CornerRadius="14" Background="#CC1B1B1F">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.6" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="14" Padding="18,14" Background="Transparent" MouseLeftButtonDown="OnDragBar">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                <TextBlock x:Name="StatusText" Style="{StaticResource CaptionText}"
                           Text="Press Ctrl+Shift+Space to transcribe the last 5s"/>

                <TextBlock x:Name="OriginalText" Style="{StaticResource PrimaryText}"
                           Margin="0,6,0,0" Visibility="Collapsed"/>

                <TextBlock x:Name="TranslationText" Style="{StaticResource SecondaryText}"
                           Margin="0,4,0,0" Visibility="Collapsed"/>

                <!-- Result player: only play/stop the clip that was sent. -->
                <Button x:Name="ResultPlayButton" Style="{StaticResource FlatButton}"
                        Content="&#x25B6;" MinWidth="0" Width="44"
                        HorizontalAlignment="Left" Margin="0,10,0,0"
                        Visibility="Collapsed" Click="OnResultPlayClick"/>

                <!-- Trim player: listen and select the clip to transcribe. -->
                <StackPanel x:Name="ReviewPanel" Visibility="Collapsed" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="ReviewPlayButton" Style="{StaticResource FlatButton}"
                                Content="&#x25B6;" MinWidth="0" Width="44" Click="OnReviewPlayClick"/>
                        <TextBlock x:Name="TimeLabel" Style="{StaticResource CaptionText}"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0" Text="00:00.0 / 00:00.0"/>
                    </StackPanel>

                    <Canvas x:Name="TrimTrack" Width="560" Height="46" Margin="0,14,0,0"
                            HorizontalAlignment="Left" Background="Transparent"
                            MouseLeftButtonDown="OnTrackClick">
                        <Border Width="560" Height="22" Canvas.Top="12"
                                CornerRadius="4" Background="{StaticResource TrackBrush}"/>
                        <Border x:Name="LeftDim" Height="22" Canvas.Top="12" Canvas.Left="0"
                                Background="#73000000"/>
                        <Border x:Name="RightDim" Height="22" Canvas.Top="12"
                                Background="#73000000"/>
                        <Thumb x:Name="SelectionBar" Height="22" Canvas.Top="12"
                               Style="{StaticResource SelectionThumb}"
                               DragDelta="OnSelectionDrag"/>
                        <Rectangle x:Name="Playhead" Width="2" Height="46" Fill="White" Visibility="Collapsed">
                            <Rectangle.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.9" Color="White"/>
                            </Rectangle.Effect>
                        </Rectangle>
                        <Thumb x:Name="StartThumb" Style="{StaticResource TrimThumb}"
                               DragDelta="OnStartThumbDrag"/>
                        <Thumb x:Name="EndThumb" Style="{StaticResource TrimThumb}"
                               DragDelta="OnEndThumbDrag"/>
                    </Canvas>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Style="{StaticResource FlatButton}"
                                Content="Cancel" Margin="0,0,10,0" Click="OnReviewCancelClick"/>
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="Send" Click="OnReviewSendClick"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="PhrasesButton" Style="{StaticResource OverlayIconButton}"
                        Width="Auto" MinWidth="34" Content="&#x2630;"
                        ToolTip="Phrases" Click="OnPhrasesClick"/>
                <Button Style="{StaticResource OverlayIconButton}"
                        Content="&#x2699;" ToolTip="Settings" Click="OnSettingsClick"/>
                <Button Style="{StaticResource OverlayCloseButton}"
                        Content="&#x2715;" ToolTip="Close" Click="OnCloseClick"/>
                <Button x:Name="AddButton" Style="{StaticResource FlatButton}"
                        Content="Add" Margin="8,0,8,0" Visibility="Collapsed" Click="OnAddClick"/>
                <Button x:Name="DoneButton" Style="{StaticResource PrimaryButton}"
                        Content="Done" Visibility="Collapsed" Click="OnDoneClick"/>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</Window>
