<Window x:Class="LangBoost.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LangBoost"
        Width="900"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Draggable trim handle: small rounded grip sized for the thin timeline. -->
        <Style x:Key="TrimThumb" TargetType="Thumb">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" CornerRadius="5" Background="{StaticResource AccentBrush}"
                                BorderBrush="White" BorderThickness="1.5"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Selection region: solid accent fill; drag to shift the whole [start,end] window. -->
        <Style x:Key="SelectionThumb" TargetType="Thumb">
            <Setter Property="Cursor" Value="ScrollAll"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" CornerRadius="3" Background="{StaticResource AccentBrush}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Margin gives the drop shadow room to render as a soft rounded glow instead of
         being clipped by the window bounds into a rectangular halo.
         The shadow lives on a dedicated background layer with no children: applying an
         Effect rasterises the whole subtree (and drops ClearType), so the text must NOT
         sit under the effect — it goes in a separate, effect-free content layer on top. -->
    <Grid Margin="22">
        <Border CornerRadius="18" Background="#E6131318">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.6" Color="Black"/>
            </Border.Effect>
        </Border>

        <Border CornerRadius="18" Padding="18,14" Background="Transparent" MouseLeftButtonDown="OnDragBar">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,0" VerticalAlignment="Center">
                <!-- Status line: an indeterminate spinner (shown while busy) + the message.
                     A Grid keeps the message wrapping in the remaining width; the spinner's
                     Auto column collapses to zero when hidden. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Canvas x:Name="Spinner" Grid.Column="0" Width="16" Height="16" Margin="0,0,10,0"
                            VerticalAlignment="Center" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                        <Ellipse Width="16" Height="16" Stroke="#553A3A42" StrokeThickness="2"/>
                        <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 8,1 A 7,7 0 0 1 15,8"/>
                        <Canvas.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate"/>
                        </Canvas.RenderTransform>
                    </Canvas>
                    <TextBlock x:Name="StatusText" Grid.Column="1" Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center"
                               Text="Press Ctrl+Enter to transcribe the last 5s"/>
                </Grid>

                <!-- Idle-only: same action as the Ctrl+Enter hotkey. Aligned (no top margin) so
                     it sits on the same line as the phrases/settings/close buttons. -->
                <Button x:Name="CaptureButton" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Left" Margin="0"
                        Visibility="Collapsed" Click="OnCaptureClick">
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource ShortcutChip}">
                            <TextBlock x:Name="CaptureChip" Style="{StaticResource ShortcutChipText}" Text="Ctrl+Enter"/>
                        </Border>
                        <TextBlock x:Name="CaptureLabel" VerticalAlignment="Center" Margin="10,0,0,0" Text="Capture"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="OriginalText" Style="{StaticResource PrimaryText}"
                           Margin="0,6,0,0" Visibility="Collapsed"/>

                <TextBlock x:Name="TranslationText" Style="{StaticResource SecondaryText}"
                           Margin="0,4,0,0" Visibility="Collapsed"/>

                <!-- Result player: only play/stop the clip that was sent. -->
                <Button x:Name="ResultPlayButton" Style="{StaticResource FlatButton}"
                        Content="&#x1F50A;" FontFamily="Segoe UI Emoji" MinWidth="0" Width="44"
                        HorizontalAlignment="Left" Margin="0,10,0,0"
                        Visibility="Collapsed" Click="OnResultPlayClick"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="PhrasesButton" Style="{StaticResource OverlayIconButton}"
                            Width="Auto" MinWidth="34" Content="&#x2630;"
                            ToolTip="Phrases" Click="OnPhrasesClick"/>
                    <Button Style="{StaticResource OverlayIconButton}"
                            Content="&#x2699;" ToolTip="Settings" Click="OnSettingsClick"/>
                    <Button Style="{StaticResource OverlayCloseButton}"
                            Content="&#x2715;" ToolTip="Close" Click="OnCloseClick"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button x:Name="AddButton" Style="{StaticResource FlatButton}"
                            Content="Add" Margin="0,0,8,0" ToolTip="Add phrase"
                            Visibility="Collapsed" Click="OnAddClick"/>
                    <Button x:Name="DoneButton" Style="{StaticResource PrimaryButton}"
                            Visibility="Collapsed" Click="OnDoneClick">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource ShortcutChip}">
                                <TextBlock Style="{StaticResource ShortcutChipText}" Text="Enter"/>
                            </Border>
                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="Done"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Trim player: listen and select the clip to transcribe.
                 Spans both columns so the buttons align with the overlay's right edge. -->
            <StackPanel x:Name="ReviewPanel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Visibility="Collapsed" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ReviewPlayButton" Style="{StaticResource FlatButton}"
                            Content="&#x1F50A;" FontFamily="Segoe UI Emoji" MinWidth="0" Width="44" Click="OnReviewPlayClick"/>
                    <TextBlock x:Name="TimeLabel" Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0" Text="00:00.0 / 00:00.0"/>
                </StackPanel>

                <!-- Timeline + actions on one line: the thin track fills the remaining width
                     (responsive; sized in code from TrimTrack.ActualWidth — see OnTrackSizeChanged),
                     Cancel/Send sit in an Auto column on the right. -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Canvas x:Name="TrimTrack" Grid.Column="0" Height="24" VerticalAlignment="Center"
                            Background="Transparent"
                            MouseLeftButtonDown="OnTrackClick" SizeChanged="OnTrackSizeChanged">
                        <Border x:Name="TrackBg" Height="6" Canvas.Top="9"
                                CornerRadius="3" Background="{StaticResource TrackBrush}"/>
                        <Border x:Name="LeftDim" Height="6" Canvas.Top="9" Canvas.Left="0"
                                CornerRadius="3" Background="#73000000"/>
                        <Border x:Name="RightDim" Height="6" Canvas.Top="9"
                                CornerRadius="3" Background="#73000000"/>
                        <Thumb x:Name="SelectionBar" Height="6" Canvas.Top="9"
                               Style="{StaticResource SelectionThumb}"
                               DragDelta="OnSelectionDrag"/>
                        <Rectangle x:Name="Playhead" Width="2" Height="24" Fill="White" Visibility="Collapsed">
                            <Rectangle.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.9" Color="White"/>
                            </Rectangle.Effect>
                        </Rectangle>
                        <Thumb x:Name="StartThumb" Canvas.Top="2" Style="{StaticResource TrimThumb}"
                               DragDelta="OnStartThumbDrag"/>
                        <Thumb x:Name="EndThumb" Canvas.Top="2" Style="{StaticResource TrimThumb}"
                               DragDelta="OnEndThumbDrag"/>
                    </Canvas>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,0,0">
                        <Button Style="{StaticResource FlatButton}"
                                Content="Cancel" Margin="0,0,10,0" Click="OnReviewCancelClick"/>
                        <Button Style="{StaticResource PrimaryButton}" Click="OnReviewSendClick">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource ShortcutChip}">
                                    <TextBlock Style="{StaticResource ShortcutChipText}" Text="Enter"/>
                                </Border>
                                <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Text="Send"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</Window>
